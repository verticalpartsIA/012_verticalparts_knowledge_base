{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "{{ schema_id }}",
  "title": "{{ method }}",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "call": {
      "const": "{{ method }}"
    },
    "param": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "required": ["call", "param"]
}

