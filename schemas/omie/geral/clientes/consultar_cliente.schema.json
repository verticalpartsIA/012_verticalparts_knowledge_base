{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verticalparts.local/schemas/omie/geral/clientes/consultar_cliente.schema.json",
  "title": "ConsultarCliente",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "call": {
      "const": "ConsultarCliente"
    },
    "param": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "codigo_cliente_omie": {
            "type": "integer"
          },
          "codigo_cliente_integracao": {
            "type": "string",
            "maxLength": 60
          }
        },
        "anyOf": [
          {
            "required": ["codigo_cliente_omie"]
          },
          {
            "required": ["codigo_cliente_integracao"]
          }
        ]
      }
    }
  },
  "required": ["call", "param"]
}
